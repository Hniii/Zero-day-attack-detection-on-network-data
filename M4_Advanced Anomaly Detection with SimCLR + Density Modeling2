":{}},{"output_type":"display_data","data":{"text/plain":["\u001b[1m Total params: \u001b[0m\u001b[38;5;34m0\u001b[0m (0.00 B)\n"],"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Total params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">0</span> (0.00 B)\n","</pre>\n"]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["\u001b[1m Trainable params: \u001b[0m\u001b[38;5;34m0\u001b[0m (0.00 B)\n"],"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Trainable params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">0</span> (0.00 B)\n","</pre>\n"]},"metadata":{}},{"output_type":"display_data","data":{"text/plain":["\u001b[1m Non-trainable params: \u001b[0m\u001b[38;5;34m0\u001b[0m (0.00 B)\n"],"text/html":["<pre style=\"white-space:pre;overflow-x:auto;line-height:normal;font-family:Menlo,'DejaVu Sans Mono',consolas,'Courier New',monospace\"><span style=\"font-weight: bold\"> Non-trainable params: </span><span style=\"color: #00af00; text-decoration-color: #00af00\">0</span> (0.00 B)\n","</pre>\n"]},"metadata":{}}],"source":["import tensorflow as tf\n","from tensorflow.keras import layers, Model\n","from tensorflow.keras.initializers import GlorotUniform, GlorotNormal\n","\n","latent_dim = 16\n","input_dim = embeddings_normal_scaled.shape[1]\n","# Encoder definition\n","class Encoder(Model):\n","    def __init__(self, latent_dim):\n","        super(Encoder, self).__init__()\n","        self.dense1 = layers.Dense(64, activation='relu', kernel_initializer=GlorotUniform())\n","        self.dense2 = layers.Dense(32, activation='relu', kernel_initializer=GlorotUniform())\n","        self.z_mean = layers.Dense(latent_dim, kernel_initializer=GlorotUniform())\n","        self.z_log_var = layers.Dense(latent_dim, kernel_initializer=GlorotUniform())\n","\n","    def call(self, inputs):\n","        x = self.dense1(inputs)\n","        x = self.dense2(x)\n","        z_mean = self.z_mean(x)\n","        z_log_var = self.z_log_var(x)\n","        return z_mean, z_log_var\n","\n","# Sampling function using the reparameterization trick\n","def sampling(args):\n","    z_mean, z_log_var = args\n","    epsilon = tf.random.normal(shape=(tf.shape(z_mean)[0], latent_dim))\n","    return z_mean + tf.exp(0.5 * z_log_var) * epsilon\n","\n","# Decoder definition\n","class Decoder(Model):\n","    def __init__(self, original_dim):\n","        super(Decoder, self).__init__()\n","        self.dense1 = layers.Dense(32, activation='relu', kernel_initializer=GlorotUniform())\n","        self.dense2 = layers.Dense(64, activation='relu', kernel_initializer=GlorotNormal())\n","        self.out = layers.Dense(original_dim, activation='sigmoid')\n","\n","    def call(self, inputs):\n","        x = self.dense1(inputs)\n","        x = self.dense2(x)\n","        return self.out(x)\n","\n","# VAE model combining encoder and decoder\n","class VAE(Model):\n","    def __init__(self, encoder, decoder, input_dim, **kwargs):\n","        super(VAE, self).__init__(**kwargs)\n","        self.encoder = encoder\n","        self.decoder = decoder\n","        self.input_dim = input_dim\n","\n","    def call(self, inputs):\n","        z_mean, z_log_var = self.encoder(inputs)\n","        z = sampling((z_mean, z_log_var))\n","        reconstruction = self.decoder(z)\n","        reconstruction_loss = tf.reduce_mean(tf.keras.losses.mse(inputs, reconstruction)) * self.input_dim\n","        epsilon = 1e-8\n","        kl_loss = 1 + z_log_var - tf.square(z_mean) - tf.exp(z_log_var)\n","        kl_loss = -0.5 * tf.reduce_mean(kl_loss + epsilon)\n","        total_loss = reconstruction_loss + kl_loss\n","        self.add_loss(total_loss)\n","        return reconstruction\n","\n","encoder = Encoder(latent_dim)\n","decoder = Decoder(input_dim)\n","vae = VAE(encoder, decoder, input_dim)\n","\n","optimizer = tf.keras.optimizers.Adam(learning_rate=1e-4, clipvalue=0.5)\n","vae.compile(optimizer=optimizer)\n","vae.build(input_shape=(None, input_dim))\n","vae.summary()\n"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":13987,"status":"ok","timestamp":1745938207529,"user":{"displayName":"George Ayman","userId":"09714939482237938277"},"user_tz":-180},"id":"oSjGM1enEdyg","outputId":"78df7d9d-af51-44e7-faa1-e63abab8cea3"},"outputs":[{"output_type":"stream","name":"stdout","text":["\u001b[1m2742/2742\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m13s\u001b[0m 3ms/step - loss: 4.2197 - val_loss: 0.4780\n"]}],"source":["vae.fit(embeddings_normal_scaled, epochs=1, batch_size=128, validation_split=0.1)\n","vae.save(\"/content/drive/MyDrive/zeroday_detection/models/vae_normal_v2.keras\")\n"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"GpuMCuMeEpAz"},"outputs":[],"source":["vae.save(\"/content/drive/MyDrive/zeroday_detection/models/vae_normal_v1.keras\")\n"]},{"cell_type":"markdown","metadata":{"id":"DPMVt2EQyvBd"},"source":["# **Step 4.4: Compute Anomaly Scores using the VAE**"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"IG5yVW5Myusf"},"outputs":[],"source":["def compute_vae_reconstruction_error(model, data):\n","    reconstructions = model.predict(data)\n","    errors = np.mean(np.abs(reconstructions - data), axis=1)\n","    return errors"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":168536,"status":"ok","timestamp":1745938393073,"user":{"displayName":"George Ayman","userId":"09714939482237938277"},"user_tz":-180},"id":"SyKXbgTgy4r1","outputId":"e26e83cf-7bb5-435a-c3f1-db32c0c10678"},"outputs":[{"output_type":"stream","name":"stdout","text":["\u001b[1m12187/12187\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m18s\u001b[0m 1ms/step\n","\u001b[1m50444/50444\u001b[0m \u001b[32m━━━━━━━━━━━━━━━━━━━━\u001b[0m\u001b[37m\u001b[0m \u001b[1m74s\u001b[0m 1ms/step\n"]}],"source":["errors_normal_vae = compute_vae_reconstruction_error(vae, embeddings_normal_scaled)\n","errors_attack_vae = compute_vae_reconstruction_error(vae, embeddings_attack_scaled)\n"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":564},"executionInfo":{"elapsed":4256,"status":"ok","timestamp":1745938402540,"user":{"displayName":"George Ayman","userId":"09714939482237938277"},"user_tz":-180},"id":"SAb0hbiDy9AJ","outputId":"b96b026c-a844-400f-b47c-d0f3c5934ffd"},"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 800x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["\n","# Plot the reconstruction error distributions\n","import matplotlib.pyplot as plt\n","import seaborn as sns\n","\n","plt.figure(figsize=(8,6))\n","sns.histplot(errors_normal_vae, bins=50, kde=True, label=\"Normal (VAE)\", color='blue')\n","sns.histplot(errors_attack_vae, bins=50, kde=True, label=\"Attack (VAE)\", color='red')\n","plt.xlabel(\"VAE Reconstruction Error\")\n","plt.ylabel(\"Frequency\")\n","plt.title(\"VAE Reconstruction Error Distributions\")\n","plt.legend()\n","plt.show()\n"]},{"cell_type":"markdown","metadata":{"id":"VoDDcGgQy_2g"},"source":["#**Step 4.5: Set Anomaly Detection Threshold for the VAE**"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":26,"status":"ok","timestamp":1745938407731,"user":{"displayName":"George Ayman","userId":"09714939482237938277"},"user_tz":-180},"id":"KtBB7G23zD8l","outputId":"9391502a-02b4-46de-c294-60d71858827b"},"outputs":[{"output_type":"stream","name":"stdout","text":["Chosen VAE threshold (99th percentile): 0.058615126\n","Chosen VAE threshold (95th percentile): 0.07022513\n","Chosen VAE threshold (99th percentile): 0.10108819\n"]}],"source":["# For example, using the 95th percentile of normal reconstruction errors\n","threshold_vae = np.percentile(errors_normal_vae, 90)\n","print(\"Chosen VAE threshold (99th percentile):\", threshold_vae)\n","threshold_vae = np.percentile(errors_normal_vae, 95)\n","print(\"Chosen VAE threshold (95th percentile):\", threshold_vae)\n","threshold_vae = np.percentile(errors_normal_vae, 99)\n","print(\"Chosen VAE threshold (99th percentile):\", threshold_vae)"]},{"cell_type":"markdown","metadata":{"id":"CAL1RUw9zOmP"},"source":["#**Step 4.6: Evaluate VAE-Based Anomaly Detection**"]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":856},"executionInfo":{"elapsed":3627,"status":"ok","timestamp":1745938423790,"user":{"displayName":"George Ayman","userId":"09714939482237938277"},"user_tz":-180},"id":"sqjMbUY9zXKw","outputId":"7098f542-af14-4793-f99d-394824b3740a"},"outputs":[{"output_type":"stream","name":"stdout","text":["VAE Confusion Matrix:\n"," [[ 386056    3900]\n"," [1600369   13813]]\n","\n","VAE Classification Report:\n","               precision    recall  f1-score   support\n","\n","      Normal       0.19      0.99      0.32    389956\n","      Attack       0.78      0.01      0.02   1614182\n","\n","    accuracy                           0.20   2004138\n","   macro avg       0.49      0.50      0.17   2004138\n","weighted avg       0.67      0.20      0.08   2004138\n","\n","F1 Score: 0.016928785246599812\n","VAE ROC AUC: 0.98760718021806\n"]},{"output_type":"display_data","data":{"text/plain":["<Figure size 800x600 with 1 Axes>"],"image/png":"\n"},"metadata":{}}],"source":["from sklearn.metrics import confusion_matrix,f1_score,  classification_report, roc_curve, auc\n","\n","y_true = np.concatenate([np.zeros(len(errors_normal_vae)), np.ones(len(errors_attack_vae))])\n","y_pred = np.concatenate([\n","    errors_normal_vae > threshold_vae,\n","    errors_attack_vae > threshold_vae\n","]).astype(int)\n","\n","# Confusion Matrix and Classification Report\n","cm_vae = confusion_matrix(y_true, y_pred)\n","print(\"VAE Confusion Matrix:\\n\", cm_vae)\n","print(\"\\nVAE Classification Report:\\n\", classification_report(y_true, y_pred, target_names=[\"Normal\", \"Attack\"]))\n","\n","# F1 Score\n","f1 = f1_score(y_true, y_pred.round())\n","print(f\"F1 Score: {f1}\")\n","\n","# Compute ROC Curve and AUC for VAE-based detection\n","# Assume errors_normal_vae and errors_attack_vae are already computed.\n","\n","# Build the true labels array for VAE errors.\n","y_true_vae = np.concatenate([np.zeros(len(errors_normal_vae)), np.ones(len(errors_attack_vae))])\n","\n","# Concatenate the errors.\n","all_errors_vae = np.concatenate([errors_normal_vae, errors_attack_vae])\n","\n","# Create a mask to filter out NaN values.\n","mask = ~np.isnan(all_errors_vae)\n","filtered_errors_vae = all_errors_vae[mask]\n","filtered_y_true_vae = y_true_vae[mask]\n","\n","# Now compute the ROC Curve and AUC with the filtered values.\n","from sklearn.metrics import roc_curve, auc\n","fpr_vae, tpr_vae, _ = roc_curve(filtered_y_true_vae, filtered_errors_vae)\n","roc_auc_vae = auc(fpr_vae, tpr_vae)\n","print(\"VAE ROC AUC:\", roc_auc_vae)\n","\n","# Plotting the ROC Curve.\n","import matplotlib.pyplot as plt\n","plt.figure(figsize=(8,6))\n","plt.plot(fpr_vae, tpr_vae, label=f\"VAE ROC (AUC = {roc_auc_vae:.2f})\", color=\"red\")\n","plt.plot([0, 1], [0, 1], linestyle=\"--\", color=\"gray\")\n","plt.xlabel(\"False Positive Rate\")\n","plt.ylabel(\"True Positive Rate\")\n","plt.title(\"ROC Curve for VAE-based Anomaly Detection\")\n","plt.legend()\n","plt.show()\n","\n"]},{"cell_type":"code","source":["print(\"NaNs in normal embeddings:\", np.isnan(embeddings_normal_scaled).any())\n","print(\"NaNs in attack embeddings:\", np.isnan(embeddings_attack_scaled).any(